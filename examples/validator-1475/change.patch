+func TestE164Validation(t *testing.T) {
+	tests := []struct {
+		param    string
+		expected bool
+	}{
+		{"", false},
+		{"+", false},
+		{"123456789", false},
+		{"+0123456789", false},
+		{"+1123456789", true},
+		{"+441234567890", true},
+		{"+19876543210", true},
+		{"+123456", false},          // too short (only 6 digits after +)
+		{"+1234567890123456", false}, // too long (16 digits after +)
+	}
+
+	validate := New()
+
+	for i, test := range tests {
+		errs := validate.Var(test.param, "e164")
+
+		if test.expected {
+			if !IsEqual(errs, nil) {
+				t.Fatalf("Index: %d e164 failed Error: %s", i, errs)
+			}
+		} else {
+			if IsEqual(errs, nil) {
+				t.Fatalf("Index: %d e164 failed Error: %s", i, errs)
+			} else {
+				val := getError(errs, "", "")
+				if val.Tag() != "e164" {
+					t.Fatalf("Index: %d e164 failed Error: %s", i, errs)
+				}
+			}
+		}
+	}
+}
